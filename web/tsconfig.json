{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noEmitOnError": true,
    "rootDir": ".",
    "outDir": ".build",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["node", "vitest/globals", "vite/client"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "vite.config.ts"]
}
